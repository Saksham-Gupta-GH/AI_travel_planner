rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the calling user's role from their users doc
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isAgent() {
      return isSignedIn() && userRole() == 'agent';
    }

    function isTraveler() {
      return isSignedIn() && userRole() == 'traveler';
    }

    // ── USERS ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone signed in can read their own doc; admins can read all
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // A user can create their own doc on registration
      allow create: if isSignedIn() && request.auth.uid == userId;

      // A user can update their own non-role, non-approved fields;
      // only admins can change role or isApproved
      allow update: if isSignedIn() && (
        (request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'isApproved'])) ||
        isAdmin()
      );

      // Only admins can delete users
      allow delete: if isAdmin();

      // Admins need to list all users; agents/travelers cannot
      allow list: if isAdmin();
    }

    // ── PACKAGES ─────────────────────────────────────────────────────────────
    match /packages/{packageId} {
      // All signed-in users can read/list packages
      allow read, list: if isSignedIn();

      // Only agents can create packages (and they own them)
      allow create: if isAgent() &&
        request.resource.data.agentId == request.auth.uid;

      // Only the owning agent or an admin can update/delete a package
      allow update, delete: if isSignedIn() && (
        (isAgent() && resource.data.agentId == request.auth.uid) ||
        isAdmin()
      );
    }

    // ── BOOKINGS ─────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Travelers can read their own bookings; agents and admins can read all
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isAgent() ||
        isAdmin()
      );

      // List: agents and admins can list all; travelers handled via read
      allow list: if isSignedIn() && (isAgent() || isAdmin());

      // Only travelers can create a booking for themselves
      allow create: if isTraveler() &&
        request.resource.data.userId == request.auth.uid;

      // Agents can update status/agentMessage/declineReason only
      // Travelers can cancel their own booking
      // Admins can do anything
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isAgent() && request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['status', 'agentMessage', 'declineReason'])) ||
        (isTraveler() && resource.data.userId == request.auth.uid &&
          request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['status']))
      );

      // Travelers can delete their own bookings; admins can delete any
      allow delete: if isSignedIn() && (
        (isTraveler() && resource.data.userId == request.auth.uid) ||
        isAdmin()
      );
    }

    // ── REVIEWS ──────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Anyone signed in can read reviews
      allow read, list: if isSignedIn();

      // Only travelers can create reviews for themselves
      allow create: if isTraveler() &&
        request.resource.data.userId == request.auth.uid;

      // Only the author or an admin can update/delete
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
